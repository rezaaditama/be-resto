datasource db {
  provider = "postgresql"
}

model menus {
  id           String        @id(map: "menu_pkey") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String        @db.VarChar(50)
  price        Decimal       @db.Decimal(12, 2)
  description  String?
  category     category
  image_path   String?       @db.VarChar(255)
  stock        Int?          @default(0)
  is_available Boolean?      @default(true)
  created_at   DateTime      @default(now()) @db.Timestamp(6)
  updated_at   DateTime?     @updatedAt @db.Timestamp(6)
  order_items  order_items[]
}

model order_items {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id  String?
  menu_id   String? @db.Uuid
  quantity  Int
  notes     String?
  sub_total Decimal @db.Decimal(12, 2)
  menu      menus?  @relation(fields: [menu_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  order     orders? @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model orders {
  id                 String        @id
  table_id           Int?
  staff_id           String?       @db.Uuid
  customer_id        String?       @db.Uuid
  discount_id        Int?
  taxes_id           Int?
  address_id         String?       @db.Uuid
  source             order_source
  status             order_status
  // keuangan
  total_amount       Decimal       @db.Decimal(12, 2)
  discount_amount    Decimal       @db.Decimal(12, 2)
  tax_amount         Decimal       @db.Decimal(12, 2)
  grand_total_amount Decimal       @db.Decimal(12, 2)
  // end
  order_number       Int           @default(autoincrement())
  created_at         DateTime      @default(now()) @db.Timestamp(6)
  validated_at       DateTime?     @db.Timestamp(6)
  cooking_started_at DateTime?     @db.Timestamp(6)
  ready_at           DateTime?     @db.Timestamp(6)
  completed_at       DateTime?     @db.Timestamp(6)
  expired_at         DateTime?     @db.Timestamp(6)
  staff              staff?        @relation(fields: [staff_id], references: [id], onUpdate: NoAction)
  customers          customers?    @relation(fields: [customer_id], references: [id], onUpdate: NoAction)
  table              tables?       @relation(fields: [table_id], references: [id], onUpdate: NoAction)
  discount           discount?     @relation(fields: [discount_id], references: [id])
  taxes              taxes?        @relation(fields: [taxes_id], references: [id])
  address            address?      @relation(fields: [address_id], references: [id], onUpdate: NoAction)
  order_items        order_items[]
  payments           payments[]
}

model payments {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id    String?
  amount_paid Decimal  @db.Decimal(12, 2)
  bank_name   String?  @db.VarChar(50)
  created_at  DateTime @default(now()) @db.Timestamp(6)
  order       orders?  @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "payments_orders_id_fkey")
}

model staff {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String         @unique @db.VarChar(100)
  password      String         @db.VarChar(255)
  fullname      String         @db.VarChar(100)
  phone_number  String?        @db.VarChar(20)
  role          role
  gender        gender_option?
  date_of_birth DateTime?      @db.Date
  is_active     Boolean?       @default(true)
  created_at    DateTime       @default(now()) @db.Timestamp(6)
  updated_at    DateTime?      @updatedAt @db.Timestamp(6)
  orders        orders[]
}

model customers {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email            String         @unique @db.VarChar(100)
  password         String         @db.VarChar(255)
  fullname         String         @db.VarChar(100)
  phone_number     String?        @db.VarChar(20)
  otp_code         Int?
  gender           gender_option?
  date_of_birth    DateTime?      @db.Date
  is_validate      Boolean?       @default(false)
  created_at       DateTime       @default(now()) @db.Timestamp(6)
  updated_at       DateTime?      @updatedAt @db.Timestamp(6)
  otp_validated_at DateTime?      @db.Timestamp(6)
  otp_expired_at   DateTime?      @db.Timestamp(6)
  orders           orders[]
  address          address[]
}

model address {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id     String?    @db.Uuid
  address_name    String     @db.VarChar(255)
  latitude        Float?
  longitude       Float?
  is_core_address Boolean?   @default(false)
  mark_as         String?
  created_at      DateTime   @default(now()) @db.Timestamp(6)
  updated_at      DateTime?  @updatedAt @db.Timestamp(6)
  customers       customers? @relation(fields: [customer_id], references: [id])
  orders          orders[]
}

model tables {
  id           Int           @id @default(autoincrement())
  table_number String        @unique @db.VarChar(10)
  capacity     Int
  status       table_status? @default(AVAILABLE)
  created_at   DateTime      @default(now()) @db.Timestamp(6)
  updated_at   DateTime?     @updatedAt @db.Timestamp(6)
  orders       orders[]
}

model discount {
  id            Int       @id @default(autoincrement())
  discount_code String    @unique @db.VarChar(10)
  description   String?
  value         Decimal   @db.Decimal(12, 2)
  min_purches   Decimal?  @db.Decimal(12, 2)
  is_active     Boolean?  @default(true)
  created_at    DateTime  @default(now()) @db.Timestamp(6)
  updated_at    DateTime? @updatedAt @db.Timestamp(6)
  orders        orders[]
}

model taxes {
  id         Int       @id @default(autoincrement())
  name       String    @db.VarChar(50)
  rate       Int
  is_active  Boolean?  @default(true)
  created_at DateTime  @default(now()) @db.Timestamp(6)
  updated_at DateTime? @updatedAt @db.Timestamp(6)
  orders     orders[]
}

enum order_source {
  KIOSK
  CASHIER
  WAITER
  ONLINE
  QR_SCAN
}

enum order_status {
  CANCELED
  PENDING
  VALIDATED
  COOKING
  READY
  COMPLETED
}

enum role {
  ADMIN
  CASHIER
  WAITER
  KIOSK_SYSTEM
  KITCHEN
}

enum table_status {
  AVAILABLE
  OCCUPIED
  DIRTY
}

enum category {
  FOOD
  DRINK
}

enum gender_option {
  MALE
  FEMALE
}