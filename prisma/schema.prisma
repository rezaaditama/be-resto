generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model customers {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username     String    @unique @db.VarChar(50)
  email        String    @unique @db.VarChar(100)
  password     String    @db.VarChar(255)
  fullname     String    @db.VarChar(100)
  phone_number String?   @db.VarChar(20)
  address      String?
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  orders       orders[]
}

model categories {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String    @unique @db.VarChar(100)
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  menus       menus[]
}

model menus {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  category_id  String?        @db.Uuid
  name         String        @db.VarChar(255)
  description  String?
  price        Decimal       @db.Decimal(12, 2)
  stock        Int?          @default(0)
  is_available Boolean?      @default(true)
  image_url    String?
  created_at   DateTime?     @default(now()) @db.Timestamptz(6)
  categories   categories?   @relation(fields: [category_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  order_items  order_items[]
}

model order_items {
  id       Int      @id @default(autoincrement())
  order_id String?  @db.Uuid
  menu_id  String?  @db.Uuid
  name     String   @db.VarChar(255)
  price    Decimal  @db.Decimal(12, 2)
  quantity Int
  notes    String?
  subtotal Decimal? @default(dbgenerated("(price * (quantity)::numeric)")) @db.Decimal(12, 2)
  menus    menus?   @relation(fields: [menu_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  orders   orders?  @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model orders {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  staff_id           String?       @db.Uuid
  customer_id        String?       @db.Uuid
  table_id           Int?
  customer_name      String?       @db.VarChar(100)
  source             order_source
  total_amount       Decimal       @default(0) @db.Decimal(12, 2)
  status             order_status? @default(PAID)
  created_at         DateTime?     @default(now()) @db.Timestamptz(6)
  validated_at       DateTime?     @db.Timestamptz(6)
  cooking_started_at DateTime?     @db.Timestamptz(6)
  ready_at           DateTime?     @db.Timestamptz(6)
  completed_at       DateTime?     @db.Timestamptz(6)
  order_items        order_items[]
  customers          customers?    @relation(fields: [customer_id], references: [id], onUpdate: NoAction)
  staff              staff?        @relation(fields: [staff_id], references: [id], onUpdate: NoAction)
  tables             tables?       @relation(fields: [table_id], references: [id], onUpdate: NoAction)
  payments           payments?
}

model payments {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id        String?         @unique @db.Uuid
  amount_paid     Decimal         @db.Decimal(12, 2)
  unique_code     Int
  payment_method  String?         @default("QRIS") @db.VarChar(20)
  status          payment_status? @default(PENDING)
  transaction_ref String?         @db.VarChar(255)
  created_at      DateTime?       @default(now()) @db.Timestamptz(6)
  orders          orders?         @relation(fields: [order_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model staff {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String     @unique @db.VarChar(100)
  username      String     @unique @db.VarChar(50)
  password      String     @db.VarChar(255)
  fullname      String     @db.VarChar(100)
  date_of_birth DateTime   @db.Date
  role          staff_role
  created_at    DateTime?  @default(now()) @db.Timestamptz(6)
  orders        orders[]
}

model tables {
  id           Int           @id @default(autoincrement())
  table_number String        @unique @db.VarChar(10)
  capacity     Int
  status       table_status? @default(AVAILABLE)
  orders       orders[]
}

enum order_source {
  KIOSK
  CASHIER
  WAITER
  ONLINE
  QR_SCAN
}

enum order_status {
  PAID
  VALIDATED
  COOKING
  READY
  SERVED
}

enum payment_status {
  PENDING
  SUCCESS
  FAILED
}

enum staff_role {
  ADMIN
  CASHIER
  WAITER
  KIOSK_SYSTEM
}

enum table_status {
  AVAILABLE
  OCCUPIED
  DIRTY
}
