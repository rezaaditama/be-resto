generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model customers {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String?        @unique @db.VarChar(255)
  password      String?        @db.VarChar(255)
  fullname      String?        @db.VarChar(255)
  phone_number  String?        @db.VarChar(20)
  address       String?
  gender        gender_option?
  date_of_birth DateTime?      @db.Date
  created_at    DateTime?      @default(now()) @db.Timestamp(6)
  updated_at    DateTime?      @default(now()) @db.Timestamp(6)
  orders        orders[]
}

model menus {
  id           String        @id(map: "menu_pkey") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String        @db.VarChar(255)
  price        Decimal       @db.Decimal(12, 2)
  description  String?
  image_path   String?       @db.VarChar(255)
  stock        Int?          @default(0)
  is_available Boolean?      @default(true)
  created_at   DateTime?     @default(now()) @db.Timestamp(6)
  updated_at   DateTime?     @default(now()) @db.Timestamp(6)
  order_items  order_items[]
}

model order_items {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id  String? @db.Uuid
  menu_id   String? @db.Uuid
  quantity  Int
  notes     String?
  sub_total Decimal @db.Decimal(12, 2)
  menu      menus?  @relation(fields: [menu_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  order     orders? @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model orders {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id        String?       @db.Uuid
  table_id           Int?
  staff_id           String?       @db.Uuid
  source             order_source
  total_amount       Decimal       @db.Decimal(12, 2)
  discount           Decimal?      @default(0) @db.Decimal(12, 2)
  order_number       Int?
  created_at         DateTime?     @default(now()) @db.Timestamp(6)
  validated_at       DateTime?     @db.Timestamp(6)
  cooking_started_at DateTime?     @db.Timestamp(6)
  ready_at           DateTime?     @db.Timestamp(6)
  completed_at       DateTime?     @db.Timestamp(6)
  order_items        order_items[]
  customer           customers?    @relation(fields: [customer_id], references: [id], onUpdate: NoAction)
  staff              staff?        @relation(fields: [staff_id], references: [id], onUpdate: NoAction)
  table              tables?       @relation(fields: [table_id], references: [id], onUpdate: NoAction)
  payments           payments[]
}

model payments {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id    String?   @db.Uuid
  amount_paid Decimal   @db.Decimal(12, 2)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  order       orders?   @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "payments_orders_id_fkey")
}

model staff {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String     @unique @db.VarChar(255)
  password      String     @db.VarChar(255)
  fullname      String     @db.VarChar(255)
  role          staff_role
  gender        String?    @db.VarChar(10)
  date_of_birth DateTime?  @db.Date
  is_active     Boolean?   @default(true)
  created_at    DateTime?  @default(now()) @db.Timestamp(6)
  updated_at    DateTime?  @default(now()) @db.Timestamp(6)
  orders        orders[]
}

model tables {
  id           Int           @id
  table_number String        @unique @db.VarChar(10)
  capacity     Int
  status       table_status? @default(AVAILABLE)
  created_at   DateTime?     @default(now()) @db.Timestamp(6)
  updated_at   DateTime?     @default(now()) @db.Timestamp(6)
  orders       orders[]
}

enum order_source {
  KIOSK
  CASHIER
  WAITER
  ONLINE
  QR_SCAN
}

enum order_status {
  PENDING
  VALIDATED
  COOKING
  READY
  COMPLETED
}

enum staff_role {
  ADMIN
  CASHIER
  WAITER
  KIOSK_SYSTEM
  KITCHEN
}

enum table_status {
  AVAILABLE
  OCCUPIED
  DIRTY
}

enum category {
  FOOD
  DRINK
}

enum gender_option {
  MALE
  FEMALE
}
